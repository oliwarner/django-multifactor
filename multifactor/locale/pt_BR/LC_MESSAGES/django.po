#: .\django-multifactor\multifactor\templates\multifactor\TOTP\add.html:3
#: .\django-multifactor\multifactor\templates\multifactor\add.html:41
msgid "Add TOTP Authenticator"
msgstr "Adicionar Autenticador TOTP"

#: .\django-multifactor\multifactor\templates\multifactor\TOTP\add.html:7
msgid ""
"Start by downloading an Authenticator App on your phone. <a href='https://"
"play.google.com/store/apps/details?"
"id=com.google.android.apps.authenticator2' target='_blank'>Google "
"Authenticator for Android</a> or <a href='https://itunes.apple.com/us/app/"
"authy/id494168017' target='_blank'>Authy for iPhones</a>. Use it to scan in "
"this QR code."
msgstr ""
"Comece baixando um aplicativo autenticador no seu telefone. <a href='https://"
"play.google.com/store/apps/details?"
"id=com.google.android.apps.authenticator2' target='_blank'>Google "
"Authenticator para Android</a> ou <a href='https://itunes.apple.com/us/app/"
"authy/id494168017' target='_blank'>Authy para iPhones</a>. Use-o para "
"escanear este código QR."

#: .\django-multifactor\multifactor\templates\multifactor\TOTP\add.html:14
msgid ""
"Once scanned, your Authenticator will give you a 6-digit, rotating code. "
"Copy that code into the box below and click Verify."
msgstr ""
"Uma vez escaneado, seu Autenticador fornecerá um código de 6 dígitos, "
"rotativo. Copie esse código na caixa abaixo e clique em Verificar."

#: .\django-multifactor\multifactor\templates\multifactor\TOTP\add.html:22
msgid "e.g 123456"
msgstr "Ex: 123456"

